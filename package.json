{
  "name": "@velocity-bpa/n8n-nodes-experian-health",
  "version": "1.0.0",
  "description": "n8n node for Experian Health healthcare data services",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://docs.n8n.io/integrations/creating-nodes/",
  "author": {
    "name": "Velocity BPA",
    "email": "info@velocitybpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/velocity-bpa/n8n-nodes-experian-health.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ExperianHealthApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ExperianHealth/ExperianHealth.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}